DirectoryIndex index.html index.php

RewriteEngine On

# Old dynamic URLs found in search results should not stay as 404s.
RewriteCond %{THE_REQUEST} \s/+index\.php\? [NC]
RewriteRule ^index\.php$ https://www.xuanfengshanghang.com/guide/? [R=301,L]

# Keep one canonical host for search engines. HTTPS forcing is handled in the
# hosting control panel because this host appears to sit behind an SSL proxy.
RewriteCond %{HTTP_HOST} !^www\.xuanfengshanghang\.com$ [NC]
RewriteRule ^ https://www.xuanfengshanghang.com%{REQUEST_URI} [R=301,L,NE]
